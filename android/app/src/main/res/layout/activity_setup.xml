<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#000000">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📱"
        android:textSize="72sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to BFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BestFoneFinder"
        android:textSize="14sp"
        android:textColor="#00C853"
        android:layout_marginBottom="40dp" />

    <!-- Password info card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="24dp"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your alarm password"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BFF"
            android:textColor="#00C853"
            android:textSize="48sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anyone who texts BFF to this number will trigger the alarm. You can change this in Settings."
            android:textColor="#777777"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

    <!-- How it works hint -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_bg_secondary"
        android:padding="14dp"
        android:layout_marginBottom="40dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡"
            android:textSize="16sp"
            android:layout_marginEnd="10dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lost your phone? Have someone text BFF to your number and it will scream at full volume — even on silent."
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="GET STARTED"
        android:textColor="#000000"
        android:background="@drawable/btn_green"
        android:textStyle="bold"
        android:textSize="16sp"
        android:stateListAnimator="@null" />

</LinearLayout>
