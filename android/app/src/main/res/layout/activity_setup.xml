<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📱"
        android:textSize="56sp"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BestFoneFinder"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Grant permissions to get started"
        android:textSize="13sp"
        android:textColor="#777777"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="28dp" />

    <!-- Permission rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="8dp"
        android:layout_marginBottom="24dp">

        <!-- SMS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/icon_circle_green"
                android:layout_marginEnd="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="📩"
                    android:textSize="18sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMS Access"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To detect the activation message"
                    android:textColor="#777777"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgSmsStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_circle_empty" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A2A" />

        <!-- Contacts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/icon_circle_green"
                android:layout_marginEnd="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="👥"
                    android:textSize="18sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contacts"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To identify who&#39;s finding your phone"
                    android:textColor="#777777"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgContactsStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_circle_empty" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A2A" />

        <!-- Notifications -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/icon_circle_green"
                android:layout_marginEnd="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🔔"
                    android:textSize="18sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To alert you when phone is found"
                    android:textColor="#777777"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgNotifStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_circle_empty" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A2A" />

        <!-- Audio Control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/icon_circle_green"
                android:layout_marginEnd="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🔊"
                    android:textSize="18sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audio Control"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To override silent mode"
                    android:textColor="#777777"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgAudioStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_circle_empty" />

        </LinearLayout>

    </LinearLayout>

    <!-- Spacer -->
    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <!-- Continue button -->
    <Button
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="GRANT PERMISSIONS"
        android:textColor="#000000"
        android:background="@drawable/btn_green"
        android:textStyle="bold"
        android:textSize="15sp"
        android:stateListAnimator="@null"
        android:layout_marginBottom="12dp" />

    <!-- Activation word info card — shown after permissions -->
    <LinearLayout
        android:id="@+id/layoutActivationInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="20dp"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅  Installation Complete!"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your activation word is"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BFF"
            android:textColor="#00C853"
            android:textSize="40sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done! Any SMS with the word BFF will activate the alarm. You can change this word in Settings and add privacy rules."
            android:textColor="#777777"
            android:textSize="12sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>

    <!-- Get Started button -->
    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="GET STARTED"
        android:textColor="#000000"
        android:background="@drawable/btn_green"
        android:textStyle="bold"
        android:textSize="15sp"
        android:stateListAnimator="@null"
        android:visibility="gone" />

</LinearLayout>
