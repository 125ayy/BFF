<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/alarmRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#00C853"
    android:gravity="center"
    android:padding="32dp">

    <!-- Bell in dark semi-transparent circle -->
    <FrameLayout
        android:id="@+id/ivBell"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bell_circle_bg"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🔔"
            android:textSize="56sp" />

    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ALARM ACTIVE"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:letterSpacing="0.05"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvTriggeredBy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Triggered by Unknown"
        android:textSize="16sp"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btnFound"
        android:layout_width="240dp"
        android:layout_height="64dp"
        android:text="FOUND!"
        android:textColor="#000000"
        android:background="@drawable/btn_white_rounded"
        android:textStyle="bold"
        android:textSize="20sp"
        android:stateListAnimator="@null"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to stop the alarm"
        android:textSize="13sp"
        android:textColor="#1A1A1A" />

</LinearLayout>
