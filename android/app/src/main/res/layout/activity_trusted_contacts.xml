<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trusted Contacts"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No trusted contacts yet.\nTap + Add to pick from your contacts."
        android:textSize="15sp"
        android:textColor="#555555"
        android:gravity="center"
        android:visibility="gone" />

    <!-- List -->
    <ListView
        android:id="@+id/lvTrustedContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#1A1A1A"
        android:dividerHeight="8dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false" />

    <!-- Add button -->
    <Button
        android:id="@+id/btnAddTrustedContact"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="+ Add Trusted Contact"
        android:textColor="#000000"
        android:background="@drawable/btn_green"
        android:textStyle="bold"
        android:textSize="15sp"
        android:stateListAnimator="@null"
        android:layout_marginTop="8dp" />

</LinearLayout>
